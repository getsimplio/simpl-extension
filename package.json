{
  "name": "simpl-extension",
  "version": "0.1.0",
  "description": "simpl — a clean, self-custodial multi-chain crypto wallet browser extension (EVM, Solana, Bitcoin, TRON).",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check:derivation": "tsx scripts/check-derivation.ts",
    "check:accounts": "tsx scripts/check-accounts.ts",
    "check:vault": "tsx scripts/check-vault.ts",
    "check:storage": "tsx scripts/check-storage.ts",
    "check:reset": "tsx scripts/check-reset.ts",
    "check:balance": "tsx scripts/check-balance.ts",
    "check:wallet": "tsx scripts/check-wallet.ts",
    "check:security": "tsx scripts/check-security.ts",
    "check:tron": "tsx scripts/check-tron.ts",
    "check:bitcoin": "tsx scripts/check-bitcoin.ts",
    "check:solana": "tsx scripts/check-solana.ts",
    "check:ton": "tsx scripts/check-ton.ts",
    "check:i18n": "tsx scripts/check-i18n.ts",
    "check:walletconnect": "tsx scripts/check-walletconnect-approval.ts",
    "check:permissions": "tsx scripts/check-permissions.ts",
    "check:risk": "tsx scripts/check-risk.ts",
    "check:endpoints": "tsx scripts/check-endpoints.ts",
    "check:proxy": "tsx scripts/check-proxy.ts",
    "check:privacy": "tsx scripts/check-privacy.ts",
    "check:manifest": "tsx scripts/check-manifest.ts",
    "check:dapp": "tsx scripts/check-dapp-permissions.ts",
    "check:release": "tsx scripts/check-release.ts",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "zip:cws": "npm run build && rm -f simpl-cws.zip && cd dist && zip -rqX ../simpl-cws.zip . -x '.DS_Store' '*/.DS_Store' '*.map' && cd .. && echo 'Packaged dist/ -> simpl-cws.zip'"
  },
  "keywords": [
    "crypto",
    "wallet",
    "ethereum",
    "solana",
    "bitcoin",
    "tron",
    "web3",
    "chrome-extension"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@reown/walletkit": "^1.5.5",
    "@scure/bip39": "^2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/vite": "^4.3.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "@types/qrcode": "^1.5.6",
    "@walletconnect/core": "^2.23.9",
    "@walletconnect/utils": "^2.23.9",
    "ethereum-blockies-base64": "^1.0.2",
    "ethers": "^6.16.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.17.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tronweb": "^6.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
