VITE_0X_API_KEY=your_0x_api_key_here
VITE_SIMPLE_SWAP_FEE_RECIPIENT=0xYOUR_FEE_WALLET_ADDRESS
VITE_SIMPLE_SWAP_FEE_BPS=50
# Simpl API Gateway base URL for market data (prices, charts), the 0x swap proxy
# AND all TON provider traffic (account, prices, jettons, send-boc, tx status —
# the getsimpl-api Worker fronts tonapi/toncenter server-side). The TON layer
# reads VITE_SIMPL_API_BASE_URL first, then VITE_SIMPL_API_URL, then the public
# default https://api.getsimpl.io. Set one base URL here.
VITE_SIMPL_API_BASE_URL=https://api.getsimpl.io
VITE_SIMPL_API_URL=https://api.getsimpl.io
VITE_SIMPL_SWAP_PROXY_URL=
VITE_WALLETCONNECT_PROJECT_ID=
# LI.FI cross-chain bridge monetization. Sent on every LI.FI quote so volume +
# collectable fees are attributed to the integrator. VITE_LIFI_FEE is a DECIMAL
# FRACTION of the route (0.005 = 0.5%, NOT 5%); invalid/empty falls back to the
# in-code default (0.005), out-of-range (>5%) disables the fee. The fee only
# accrues once a fee wallet is set for this integrator in the LI.FI Portal.
VITE_LIFI_INTEGRATOR=simpl
VITE_LIFI_FEE=0.005
# TON provider configuration.
# DEPRECATED / REMOVED: TON no longer talks to any provider directly. All TON
# traffic is proxied through the getsimpl-api Worker under
# ${VITE_SIMPL_API_BASE_URL}/v1/ton/*, so there are no client-side TON provider
# URLs or keys anymore. The following variables are intentionally gone — do NOT
# reintroduce them in the client; they would ship in the public dist bundle:
#   VITE_TON_MAINNET_API_URL   (was toncenter base)
#   VITE_TON_API_KEY           (toncenter key)
#   VITE_TONAPI_URL            (was tonapi base)
#   VITE_TONAPI_KEY            (tonapi bearer)
#   VITE_TONCENTER_API_KEY
# SECURITY: the real TON provider keys live ONLY in the getsimpl-api Worker
# secrets (server-side), never in this client .env or the extension bundle.